# Context Aware & Vision Grounded KB Agent — Next.js Web App

# Agent runtime target.
# Local dev: http://localhost:8088
# Production: APIM or internal agent Container App URL
AGENT_ENDPOINT=http://localhost:8088

# Azure Blob Storage image proxy settings.
SERVING_BLOB_ENDPOINT=https://<serving-storage-account>.blob.core.windows.net
SERVING_CONTAINER_NAME=serving

# Local blob emulator support.
AZURITE_CONNECTION_STRING=

# Lightweight conversation sidebar persistence.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_VERIFY_CERT=false
COSMOS_DATABASE_NAME=kb-agent
COSMOS_CONVERSATIONS_CONTAINER=conversations
