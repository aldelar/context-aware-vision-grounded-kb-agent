ENVIRONMENT=dev

# Service routing inside Docker Compose
AGENT_ENDPOINT=http://agent:8088

# Ollama
OLLAMA_ENDPOINT=http://ollama:11434/v1
OLLAMA_API_KEY=ollama
# Use `all` to expose every NVIDIA GPU Docker can see, or set a specific GPU UUID from `nvidia-smi -L`.
OLLAMA_GPU_DEVICE=all
AGENT_MODEL_DEPLOYMENT_NAME=qwen2.5:3b
EMBEDDING_DEPLOYMENT_NAME=mxbai-embed-large
SUMMARY_DEPLOYMENT_NAME=qwen2.5:3b
VISION_DEPLOYMENT_NAME=moondream
EMBEDDING_VECTOR_DIMENSIONS=1024

# Azure Functions base images currently publish linux/amd64 only. Keep the
# local function containers explicit so Apple Silicon and Linux ARM hosts build
# and run them through Docker emulation instead of failing manifest resolution.
AZURE_FUNCTIONS_PLATFORM=linux/amd64

# AI Search simulator
SEARCH_ENDPOINT=https://search-simulator:8443
SEARCH_API_KEY=dev-admin-key
SEARCH_VERIFY_CERT=false
SEARCH_INDEX_NAME=kb-articles
SEARCH_TEST_INDEX_NAME=kb-articles-test
# The current Search Simulator image publishes linux/amd64 only. Keep this
# explicit so Apple Silicon and Linux ARM hosts run it through Docker emulation
# without a platform mismatch warning. Remove or override if an arm64 image is
# published in the future.
SEARCH_SIMULATOR_PLATFORM=linux/amd64

# Azurite — well-known emulator default key (not a real secret)
